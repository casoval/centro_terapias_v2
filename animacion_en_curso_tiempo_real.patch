+<script>
+// ── ✅ NUEVO: actualizar "EN CURSO" en el dashboard sin recargar la página ──
+function actualizarSesionesEnCursoDashboard() {
+    var ahora = new Date();
+    var hoyStr = ahora.getFullYear() + '-' +
+        String(ahora.getMonth() + 1).padStart(2, '0') + '-' +
+        String(ahora.getDate()).padStart(2, '0');
+    var minAhora = ahora.getHours() * 60 + ahora.getMinutes();
+
+    document.querySelectorAll('.sesion-dash-live').forEach(function (card) {
+        var fecha = card.dataset.fecha;
+        var inicio = card.dataset.horaInicio;
+        var fin = card.dataset.horaFin;
+        if (!fecha || !inicio || !fin) return;
+
+        var enCurso = false;
+        if (fecha === hoyStr) {
+            var pi = inicio.split(':');
+            var pf = fin.split(':');
+            var minInicio = parseInt(pi[0], 10) * 60 + parseInt(pi[1], 10);
+            var minFin = parseInt(pf[0], 10) * 60 + parseInt(pf[1], 10);
+            enCurso = minAhora >= minInicio && minAhora < minFin;
+        }
+
+        card.classList.toggle('en-curso-dash-live', enCurso);
+        var badgeEnCurso = card.querySelector('.badge-en-curso-dash');
+        var badgeProxima = card.querySelector('.badge-proxima-dash');
+        if (badgeEnCurso) badgeEnCurso.classList.toggle('hidden', !enCurso);
+        if (badgeProxima) badgeProxima.classList.toggle('hidden', enCurso);
+    });
+}
+actualizarSesionesEnCursoDashboard();
+setInterval(actualizarSesionesEnCursoDashboard, 20000); // cada 20 segundos
+</script>
