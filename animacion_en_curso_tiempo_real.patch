+// ── ✅ NUEVO: actualizar "EN CURSO" sin recargar la página (Opción A) ──────
+// Recalcula en el navegador si cada sesión 'programada' cae dentro de su
+// horario, y prende/apaga la animación y el badge sin pedir nada al servidor.
+function actualizarSesionesEnCurso() {
+    var ahora = new Date();
+    var hoyStr = ahora.getFullYear() + '-' +
+        String(ahora.getMonth() + 1).padStart(2, '0') + '-' +
+        String(ahora.getDate()).padStart(2, '0');
+    var minAhora = ahora.getHours() * 60 + ahora.getMinutes();
+
+    document.querySelectorAll('.sesion-card-live[data-estado="programada"]').forEach(function (card) {
+        var fecha = card.dataset.fecha;
+        var inicio = card.dataset.horaInicio;
+        var fin = card.dataset.horaFin;
+        if (!fecha || !inicio || !fin) return;
+
+        var enCurso = false;
+        if (fecha === hoyStr) {
+            var pi = inicio.split(':');
+            var pf = fin.split(':');
+            var minInicio = parseInt(pi[0], 10) * 60 + parseInt(pi[1], 10);
+            var minFin = parseInt(pf[0], 10) * 60 + parseInt(pf[1], 10);
+            enCurso = minAhora >= minInicio && minAhora < minFin;
+        }
+
+        card.classList.toggle('en-curso-live', enCurso);
+        var badge = card.querySelector('.en-curso-badge');
+        if (badge) badge.classList.toggle('hidden', !enCurso);
+    });
+}
+actualizarSesionesEnCurso();
+setInterval(actualizarSesionesEnCurso, 20000); // cada 20 segundos
+
 </script>
